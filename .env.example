NODE_ENV=development
DATABASE_URL=mysql://user:password@localhost:3306/trustcare
JWT_SECRET=replace-with-at-least-32-random-characters
VITE_APP_ID=trustcare-local
TRUSTCARE_PUBLIC_URL=http://localhost:3000
TRUSTCARE_DID_DOMAIN=localhost%3A3000
TRUSTCARE_VC_SIGNING_SECRET=replace-with-a-dedicated-random-secret
TRUSTCARE_VC_SIGNING_PRIVATE_JWK=
TRUSTCARE_VC_SIGNING_PUBLIC_JWK=
TRUSTCARE_VC_KEY_ID=

# Railway Bucket or another S3-compatible private bucket
STORAGE_BACKEND=s3
BUCKET=
ACCESS_KEY_ID=
SECRET_ACCESS_KEY=
REGION=auto
ENDPOINT=https://storage.railway.app

# Demo/test deployment only
BOOTSTRAP_DEMO_DATA=false
ALLOW_PUBLIC_DEMO_SEED=false
VITE_ENABLE_DEMO_SEED_UI=false
